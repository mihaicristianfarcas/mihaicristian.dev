---
/* The slug is shared with the Romanian post, so it is the id minus its
   language prefix. */
import WritingPost from "../../components/pages/WritingPost.astro";
import { getPosts } from "../../data/writing";
import { slugOf } from "../../data/i18n";

export async function getStaticPaths() {
	const posts = await getPosts("en");
	return posts.map((post) => ({
		params: { slug: slugOf(post.id) },
		props: { post },
	}));
}

const { post } = Astro.props;
---

<WritingPost lang="en" {post} />
