---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PassionPattern from "../../components/PassionPattern.astro";
import WritingTimeline from "../../components/WritingTimeline.astro";

const posts = (
	await getCollection("writing", ({ data }) =>
		import.meta.env.PROD ? data.draft !== true : true,
	)
)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.map((p) => ({ id: p.id, title: p.data.title, date: p.data.date }));
---

<Base title="Writing" description="Notes on software and life." wide router>
  <p class="back mono"><a href="/">← home</a></p>
  {
    posts.length > 0 ? (
      <div class="layout">
        <aside transition:name="timeline" transition:persist>
          <WritingTimeline posts={posts} />
        </aside>
        <div class="blurb s" style="--i: 0">
          <h1>Writing</h1>
          <p>
            This is my blog — notes on software and life. Pick a post from the
            timeline to start reading.
          </p>
        </div>
      </div>
    ) : (
      <p class="empty s" style="--i: 0">
        Nothing here yet. Subscribe to the <a href="/rss.xml">RSS feed</a> to
        catch the first post.
      </p>
    )
  }
  <PassionPattern wide />
</Base>

<style>
  .back {
    margin-bottom: 2.5rem;
  }

  .back a {
    color: var(--muted);
    text-decoration: none;
  }

  .back a:hover {
    color: var(--accent);
  }

  .layout {
    display: grid;
    grid-template-columns: 15rem minmax(0, 65ch);
    gap: 3.5rem;
    align-items: start;
  }

  .blurb p {
    margin-top: 0.875rem;
    color: var(--muted);
  }

  .empty {
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 2.5rem;
    }

    /* The aside is transition:persist, so select it through the fresh
       .layout parent — it carries the other page's scope after navigation. */
    .layout > :global(aside) {
      order: 2;
    }
  }
</style>
