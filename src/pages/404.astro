---
/* Astro emits a single static 404.html, so this page cannot be per-language.
   It says it in both rather than stranding a Romanian visitor in English. */
import Base from "../layouts/Base.astro";
import { ui } from "../data/i18n";
---

<Base lang="en" title={ui.en.notFoundTitle} router alternates={false}>
  <h1 class="s" style="--i: 0">{ui.en.notFound}</h1>
  <p class="ro s" lang="ro" style="--i: 1">{ui.ro.notFound}</p>
  <p class="s mono links" style="--i: 2">
    <a href="/">{ui.en.backHome}</a>
    <a href="/ro/" hreflang="ro">{ui.ro.backHome}</a>
  </p>
</Base>

<style>
  .ro {
    margin-top: 0.5rem;
    color: var(--muted);
  }

  .links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.25rem;
  }

  .links a {
    color: var(--muted);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--accent);
  }
</style>
