---
/* The rail both index sections hang their list on: one quiet curve
   meandering down the band, every entry's dot sitting on it. A fresh drift
   is rolled each time a visitor enters the section (hard load, or router
   entry from a rail-less page); transition:persist keeps it frozen while
   they travel within. Groups are whatever ordering the list actually has —
   kind of work for projects, year for writing. */
import { meander, seeded } from "./meander";

interface Props {
	groups: {
		name: string;
		items: { href: string; title: string }[];
	}[];
	/* The href of the entry being viewed, if any. */
	current?: string;
	label: string;
}

const { groups, current, label } = Astro.props;

/* Fixed row and header heights keep the curve geometry locked to the list. */
const ROW = 40;
const HEAD = 34;
const W = 30;

/* One layout pass: walk the groups, handing every header and pad a y, so
   the SVG and the list agree without either measuring the other. */
const nodes: { href: string; y: number }[] = [];
let y = 0;
for (const g of groups) {
	y += HEAD;
	for (const item of g.items) {
		nodes.push({ href: item.href, y: y + ROW / 2 });
		y += ROW;
	}
}
const H = y;

/* The server curve is seeded, so no-JS visitors and the pre-reroll first
   paint get the same drift on every build. */
const { xs, d } = meander(
	nodes.map((n) => n.y),
	HEAD,
	seeded(),
);
---

<nav class="rail" aria-label={label}>
  <svg width={W} height={H} viewBox={`0 0 ${W} ${H}`} aria-hidden="true">
    <path class="meander" d={d} data-y0={HEAD} />
    {
      nodes.map((n, i) => (
        <circle
          class:list={['pad', { current: n.href === current }]}
          data-href={n.href}
          cx={xs[i]}
          cy={n.y}
          r="3"
        />
      ))
    }
  </svg>
  <div class="list">
    {
      groups.map((g) => (
        <section>
          <h2 class="mono head" style={`height: ${HEAD}px`}>
            {g.name}
          </h2>
          <ol role="list">
            {g.items.map((item) => (
              <li style={`height: ${ROW}px`}>
                <a
                  href={item.href}
                  aria-current={item.href === current ? 'page' : undefined}
                >
                  <span class="title">{item.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </section>
      ))
    }
  </div>
</nav>

<script>
  import { meander } from './meander'

  // The rail persists across client-router navigations, so its markup still
  // points at the previous entry — re-sync the highlight below.
  const normalize = (p: string) => p.replace(/\/+$/, '')

  // A freshly mounted rail (hard load, or router entry from a rail-less
  // page) rolls its own drift; the persisted node keeps data-generated, so
  // travelling within the section never redraws the curve. Runs while the
  // rail still sits at opacity 0 behind the entrance fade.
  function reroll() {
    const nav = document.querySelector('nav.rail')
    const path = nav?.querySelector<SVGPathElement>('path.meander')
    if (!nav || !path || nav.hasAttribute('data-generated')) return
    nav.setAttribute('data-generated', '')
    const dots = [...nav.querySelectorAll<SVGCircleElement>('circle[data-href]')]
    const { xs, d } = meander(
      dots.map((c) => +(c.getAttribute('cy') ?? 0)),
      +(path.dataset.y0 ?? 0),
      Math.random,
    )
    dots.forEach((c, i) => c.setAttribute('cx', `${xs[i]}`))
    path.setAttribute('d', d)
  }

  reroll()
  document.addEventListener('astro:after-swap', reroll)

  // Own scroll restoration so a mid-scroll reload doesn't leave us partway
  // down; we re-assert the top in page-load, the last hook to fire.
  history.scrollRestoration = 'manual'

  let keyboard = false
  addEventListener('keydown', () => (keyboard = true), true)
  addEventListener('pointerdown', () => (keyboard = false), true)

  document.addEventListener('astro:after-swap', () => {
    // Astro refocuses the clicked rail link, scrolling it into view.
    // Keyboard users get focus on the back link instead; pointer users a blur.
    if (keyboard) {
      document
        .querySelector<HTMLElement>('.back a')
        ?.focus({ preventScroll: true })
    } else {
      ;(document.activeElement as HTMLElement | null)?.blur?.()
    }
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' })
  })

  document.addEventListener('astro:page-load', () => {
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' })
    const nav = document.querySelector('nav.rail')
    if (!nav) return
    const here = normalize(location.pathname)
    nav.querySelectorAll('a[href]').forEach((a) => {
      const current = normalize(a.getAttribute('href') ?? '') === here
      if (current) a.setAttribute('aria-current', 'page')
      else a.removeAttribute('aria-current')
    })
    nav.querySelectorAll<SVGCircleElement>('circle[data-href]').forEach((c) => {
      c.classList.toggle('current', normalize(c.dataset.href ?? '') === here)
    })
  })
</script>

<style>
  .rail {
    position: relative;
  }

  svg {
    position: absolute;
    left: 0;
    top: 0;
  }

  .meander {
    fill: none;
    stroke: var(--muted);
    stroke-width: 1.2;
    stroke-linecap: round;
    opacity: 0.35;
  }

  .pad {
    fill: var(--bg);
    stroke: var(--muted);
    stroke-width: 1.3;
  }

  .pad.current {
    fill: var(--accent);
    stroke: var(--accent);
  }

  .list {
    margin-left: 44px;
  }

  .head {
    display: flex;
    align-items: center;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }

  ol {
    list-style: none;
    padding: 0;
  }

  li {
    display: flex;
    align-items: center;
  }

  a {
    text-decoration: none;
    color: var(--muted);
    line-height: 1.4;
    min-width: 0;
  }

  a:hover {
    color: var(--accent);
  }

  .title {
    display: block;
    font-size: 0.9375rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  a[aria-current='page'] {
    color: var(--text);
  }

  a[aria-current='page'] .title {
    font-weight: 600;
  }

</style>
