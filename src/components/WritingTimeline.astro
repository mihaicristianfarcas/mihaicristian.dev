---
interface Props {
	posts: { id: string; title: string; date: Date }[];
	current?: string;
}

const { posts, current } = Astro.props;

/* Fixed row height keeps the helix geometry aligned with the list. */
const SEG = 76;
const W = 30;
const CX = W / 2;
const AMP = 9;
const n = posts.length;
const H = SEG * n;
const firstY = SEG / 2;

/* Two strands: cubic segments bulging to opposite sides, alternating
   per segment, meeting at each post node — a flat double helix. */
function strand(dir: 1 | -1) {
	let d = `M ${CX} ${firstY}`;
	for (let i = 0; i < n - 1; i++) {
		const y0 = firstY + i * SEG;
		const y1 = y0 + SEG;
		const side = (i % 2 === 0 ? dir : -dir) * AMP;
		d += ` C ${CX + side} ${y0 + SEG / 3}, ${CX + side} ${y1 - SEG / 3}, ${CX} ${y1}`;
	}
	return d;
}

/* Base-pair rungs between the strands, three per segment. */
const rungs: { x1: number; x2: number; y: number }[] = [];
for (let i = 0; i < n - 1; i++) {
	const y0 = firstY + i * SEG;
	for (const t of [0.35, 0.5, 0.65]) {
		const half = 3 * t * (1 - t) * AMP;
		rungs.push({ x1: CX - half, x2: CX + half, y: y0 + SEG * t });
	}
}

const dateFmt = new Intl.DateTimeFormat("en", {
	month: "short",
	day: "numeric",
	year: "numeric",
});
---

<nav class="timeline" aria-label="All posts">
  <svg width={W} height={H} viewBox={`0 0 ${W} ${H}`} aria-hidden="true">
    {
      n > 1 && (
        <>
          {rungs.map((r) => (
            <line class="rung" x1={r.x1} y1={r.y} x2={r.x2} y2={r.y} />
          ))}
          <path class="strand a" d={strand(1)} />
          <path class="strand b" d={strand(-1)} />
        </>
      )
    }
    {
      posts.map((p, i) => (
        <circle
          class:list={['node', { current: p.id === current }]}
          data-href={`/writing/${p.id}/`}
          cx={CX}
          cy={firstY + i * SEG}
          r="4"
        />
      ))
    }
  </svg>
  <ol role="list">
    {
      posts.map((p) => (
        <li style={`height: ${SEG}px`}>
          <a
            href={`/writing/${p.id}/`}
            aria-current={p.id === current ? 'page' : undefined}
          >
            <span class="title">{p.title}</span>
            <span class="mono date">{dateFmt.format(p.date)}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<script>
  // The rail persists across client-router navigations, so its markup
  // still points at the previous post — re-sync the highlight below.
  const normalize = (p: string) => p.replace(/\/+$/, '')

  // Own scroll restoration so a mid-scroll reload doesn't leave us partway
  // down; we re-assert the top in page-load, the last hook to fire.
  history.scrollRestoration = 'manual'

  document.addEventListener('astro:after-swap', () => {
    // Astro restores focus to the clicked rail link and focus() scrolls it
    // into view, pulling the page back down. Hand focus to "← home" instead
    // — the first tab stop, with the post one Tab away.
    document
      .querySelector<HTMLElement>('.back a')
      ?.focus({ preventScroll: true })
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' })
  })

  document.addEventListener('astro:page-load', () => {
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' })
    const nav = document.querySelector('nav.timeline')
    if (!nav) return
    const here = normalize(location.pathname)
    nav.querySelectorAll('a[href]').forEach((a) => {
      const current = normalize(a.getAttribute('href') ?? '') === here
      if (current) a.setAttribute('aria-current', 'page')
      else a.removeAttribute('aria-current')
    })
    nav.querySelectorAll<SVGCircleElement>('circle[data-href]').forEach((c) => {
      c.classList.toggle('current', normalize(c.dataset.href ?? '') === here)
    })
  })
</script>

<style>
  .timeline {
    position: relative;
  }

  svg {
    position: absolute;
    left: 0;
    top: 0;
  }

  .strand {
    fill: none;
    stroke-width: 1.5;
  }

  .strand.a {
    stroke: var(--accent);
    opacity: 0.55;
  }

  .strand.b {
    stroke: var(--muted);
    opacity: 0.45;
  }

  .rung {
    stroke: var(--hairline);
    stroke-width: 1;
  }

  .node {
    fill: var(--bg);
    stroke: var(--muted);
    stroke-width: 1.5;
  }

  .node.current {
    fill: var(--accent);
    stroke: var(--accent);
  }

  ol {
    list-style: none;
    padding: 0;
    margin-left: 44px;
  }

  li {
    display: flex;
    align-items: center;
  }

  a {
    text-decoration: none;
    color: var(--muted);
    line-height: 1.4;
    min-width: 0;
  }

  a:hover {
    color: var(--accent);
  }

  .title {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    font-size: 0.9375rem;
    overflow: hidden;
  }

  a[aria-current='page'] {
    color: var(--text);
  }

  a[aria-current='page'] .title {
    font-weight: 600;
  }

  .date {
    display: block;
    font-size: 0.75rem;
    margin-top: 0.125rem;
  }
</style>
